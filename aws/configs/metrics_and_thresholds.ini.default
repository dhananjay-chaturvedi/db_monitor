# =============================================================================
# CATEGORY 3 - DATABASE INSIGHTS (CloudWatch DB_PERF_INSIGHTS)
# Regenerate: bash setup/assemble_thresholds_ini.sh
# =============================================================================

[metric.aws.dbinsights.RDS.db_load]
collect     = false
enabled     = false
description = DB load (avg active sessions)
metric_name = db.load.avg
engines     = mysql,mariadb,postgresql,oracle,sqlserver,aurora-mysql,aurora-postgresql,aurora
operator    = >
unit        = sessions
window      = 3
warning     = 2
critical    = 4

[metric.aws.dbinsights.RDS.db_load_cpu]
collect     = false
enabled     = false
description = DB load on CPU
metric_name = db.load.avg.cpu
engines     = mysql,mariadb,postgresql,oracle,sqlserver,aurora-mysql,aurora-postgresql,aurora
operator    = >
unit        = sessions
window      = 3
warning     = 2
critical    = 4

[metric.aws.dbinsights.RDS.db_load_non_cpu]
collect     = false
enabled     = false
description = DB load non-CPU wait
metric_name = db.load.avg.non_cpu
engines     = mysql,mariadb,postgresql,oracle,sqlserver,aurora-mysql,aurora-postgresql,aurora
operator    = >
unit        = sessions
window      = 3
warning     = 2
critical    = 4

[metric.aws.dbinsights.RDS.db_sampledload]
collect     = false
enabled     = false
description = DB sampled load (raw sessions)
metric_name = db.sampledload.avg
engines     = mysql,mariadb,postgresql,oracle,sqlserver,aurora-mysql,aurora-postgresql,aurora
operator    = >
unit        = sessions
window      = 3
warning     = 2
critical    = 4

[metric.aws.dbinsights.RDS.os_memory_active_avg]
collect     = false
enabled     = false
description = PI OS memory active
metric_name = os.memory.active.avg
engines     = mysql,mariadb,postgresql,oracle,aurora-mysql,aurora-postgresql,aurora
operator    = >
