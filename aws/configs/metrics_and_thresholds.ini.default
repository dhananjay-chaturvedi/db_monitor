
# =============================================================================
# CATEGORY 0A - HOST OS METRICS
# Local /proc (collect_localhost_os) and SSH hosts (collect_ssh_hosts_os).
# Gated by collect_os_metrics in config.ini [monitoring].
# Regenerate catalog: bash setup/assemble_thresholds_ini.sh
# =============================================================================

# =============================================================================
# HOST OS METRICS (auto-generated catalog)
#
# Keys:
#   enabled   = true | false   evaluate thresholds / fire alerts
#   operator  = > | >= | < | <= | == | !=
#   unit      = display unit for alert messages
#   window    = consecutive breaches before firing
#   warning / critical / info = optional severity thresholds
# Regenerate: bash setup/assemble_thresholds_ini.sh
# =============================================================================

[metric.os.cpu_utilization]
enabled     = false
description = Host CPU utilization
operator    = >
unit        = %
window      = 3
warning     = 80
critical    = 90

[metric.os.memory_utilization]
enabled     = false
description = Host memory utilization
operator    = >
unit        = %
window      = 3
warning     = 85
critical    = 95

[metric.os.free_memory_mb]
enabled     = false
description = Host free memory
operator    = <
unit        = MB
window      = 3
warning     = 512
critical    = 256

[metric.os.free_disk_gb]
enabled     = false
description = Host free disk space
operator    = <
unit        = GB
window      = 3
warning     = 10
critical    = 5

[metric.os.disk_utilization]
enabled     = false
description = Host disk utilization
operator    = >
unit        = %
window      = 3
warning     = 85
critical    = 95

[metric.os.load_avg_1m]
enabled     = false
description = Host load average (1 minute)
operator    = >
unit        = load
window      = 3
warning     = 4
critical    = 8

[metric.os.load_avg_5m]
enabled     = false
description = Host load average (5 minutes)
operator    = >
unit        = load
window      = 3
warning     = 4
critical    = 8

[metric.os.load_avg_15m]
enabled     = false
description = Host load average (15 minutes)
operator    = >
unit        = load
window      = 3
warning     = 4
critical    = 8

[metric.os.swap_used_mb]
enabled     = false
description = Host swap used
operator    = >
unit        = MB
window      = 3
warning     = 512
critical    = 1024

[metric.os.net_rx_bytes]
enabled     = false
description = Host network bytes received (cumulative)
operator    = >
unit        = bytes
window      = 3

[metric.os.net_tx_bytes]
enabled     = false
description = Host network bytes sent (cumulative)
operator    = >
unit        = bytes
window      = 3

[metric.os.net_rx_errors]
enabled     = false
description = Host network receive errors
operator    = >
unit        = count
window      = 3
warning     = 1
critical    = 10

[metric.os.net_tx_errors]
enabled     = false
description = Host network transmit errors
operator    = >
unit        = count
window      = 3
warning     = 1
critical    = 10


# =============================================================================
# CATEGORY 0B - DB CONNECTIVITY METRICS
# Targets from connections.tsv; gated by collect_db_metrics in config.ini.
# Regenerate catalog: bash setup/assemble_thresholds_ini.sh
# =============================================================================

# =============================================================================
# DB CONNECTIVITY METRICS (auto-generated catalog)
#
# Keys:
#   enabled   = true | false   evaluate thresholds / fire alerts
#   operator  = > | >= | < | <= | == | !=
#   unit      = display unit for alert messages
#   window    = consecutive breaches before firing
#   warning / critical / info = optional severity thresholds
# Regenerate: bash setup/assemble_thresholds_ini.sh
# =============================================================================

[metric.db.connection]
enabled     = false
description = Database connectivity check
operator    = >=
unit        = 
window      = 3
critical    = 1


# =============================================================================
# CATEGORY 1 - AWS CLOUDWATCH (RDS / Aurora)
# Gated by collect_cloud_metrics in config.ini [monitoring].
# Regenerate catalog: bash setup/assemble_thresholds_ini.sh
# =============================================================================

# =============================================================================
# AWS RDS / AURORA - CLOUDWATCH METRICS (auto-generated catalog)
# MetricName must match CloudWatch exactly (case-sensitive).
#
# Keys:
#   collect   = true | false   fetch from CloudWatch (default: false)
#   enabled   = true | false   evaluate thresholds / fire alerts
#   engines   = comma-separated instance types this rule applies to
#   dimension = instance | cluster
#   metric_name = override when section name differs from CloudWatch name
# Regenerate: bash setup/assemble_thresholds_ini.sh
# =============================================================================

[metric.aws.cloudwatch.RDS.CPUUtilization]
collect     = false
enabled     = false
description = RDS CPU utilisation
engines     = all
dimension   = instance
operator    = >
unit        = %
window      = 3
warning     = 75
critical    = 90

[metric.aws.cloudwatch.RDS.FreeableMemory]
collect     = false
enabled     = false
description = RDS freeable memory
engines     = all
dimension   = instance
operator    = <
unit        = bytes
window      = 3
warning     = 268435456
critical    = 134217728

[metric.aws.cloudwatch.RDS.SwapUsage]
collect     = false
enabled     = false
description = RDS swap usage
engines     = all
dimension   = instance
operator    = >
unit        = bytes
window      = 3
warning     = 268435456
critical    = 536870912

[metric.aws.cloudwatch.RDS.FreeStorageSpace]
collect     = false
enabled     = false
description = RDS free storage space
engines     = mysql,mariadb,postgresql,oracle,sqlserver
dimension   = instance
operator    = <
unit        = bytes
window      = 3
warning     = 5368709120
critical    = 2147483648

[metric.aws.cloudwatch.RDS.DatabaseConnections]
