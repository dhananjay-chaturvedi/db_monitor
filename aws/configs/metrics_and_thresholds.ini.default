operator    = >
unit        = ms
window      = 3
warning     = 1000
critical    = 5000

[metric.aws.cloudwatch.Aurora.AuroraGlobalDBReplicatedWriteIO]
collect     = false
enabled     = false
description = Aurora Global DB replicated write IO
engines     = aurora
dimension   = cluster
operator    = 10000
unit        = >
window      = 3
warning     = 30000
critical    = AuroraGlobalDBReplicatedWriteIO

[metric.aws.cloudwatch.Aurora.AuroraGlobalDBReplicationLag]
collect     = false
enabled     = false
description = Aurora Global DB replication lag
engines     = aurora
dimension   = cluster
operator    = >
unit        = ms
window      = 3
warning     = 1000
critical    = 5000

[metric.aws.cloudwatch.Aurora.AuroraGlobalDBRPOLag]
collect     = false
enabled     = false
description = Aurora Global DB RPO lag
engines     = aurora
dimension   = cluster
operator    = >
unit        = ms
window      = 3
warning     = 1000
critical    = 5000

[metric.aws.cloudwatch.Aurora.BacktrackChangeRecordsCreationRate]
collect     = false
enabled     = false
description = Aurora backtrack creation rate
engines     = aurora
dimension   = cluster
operator    = >
unit        = /5min
window      = 3
warning     = 1000
critical    = 5000

[metric.aws.cloudwatch.Aurora.BacktrackChangeRecordsStored]
collect     = false
enabled     = false
description = Aurora backtrack records stored
engines     = aurora
dimension   = cluster
operator    = 100000
unit        = >
window      = 3
warning     = 500000
critical    = BacktrackChangeRecordsStored

[metric.aws.cloudwatch.Aurora.BacktrackWindowActual]
collect     = false
enabled     = false
description = Aurora backtrack window actual
engines     = aurora
dimension   = cluster
operator    = <
unit        = min
window      = 3
warning     = 5
critical    = 1

[metric.aws.cloudwatch.Aurora.BacktrackWindowAlert]
collect     = false
enabled     = false
description = Aurora backtrack window alert
engines     = aurora
dimension   = cluster
operator    = 1
unit        = >
window      = 3
warning     = 5
critical    = BacktrackWindowAlert

# =============================================================================
# CATEGORY 2 - PERFORMANCE INSIGHTS (aws pi get-resource-metrics)
# Requires Performance Insights enabled on the RDS instance.
# Regenerate: bash setup/assemble_thresholds_ini.sh
# =============================================================================

[metric.aws.pi.RDS.db_load]
