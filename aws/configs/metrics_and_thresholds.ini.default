engines     = mysql,mariadb,postgresql,oracle,aurora-mysql,aurora-postgresql,aurora
operator    = >
unit        = KB
window      = 3

[metric.aws.dbinsights.RDS.os_memory_cached_avg]
collect     = false
enabled     = false
description = PI OS memory cached
metric_name = os.memory.cached.avg
engines     = mysql,mariadb,postgresql,oracle,aurora-mysql,aurora-postgresql,aurora
operator    = >
unit        = KB
